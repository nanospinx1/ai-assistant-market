# ==============================================================
# AI Assistant Market — Environment Variables
# ==============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.
# ==============================================================

# Auth secret for JWT token signing (change in production!)
AUTH_SECRET=your-secret-key-here

# Base URL for the application
NEXTAUTH_URL=http://localhost:3001

# --------------------------------------------------------------
# LLM Provider Configuration
# --------------------------------------------------------------
# Options: "azure-openai" (real API calls) or "mock" (demo mode)
LLM_PROVIDER=mock

# Azure OpenAI Configuration (required when LLM_PROVIDER=azure-openai)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY_PRIMARY=your-primary-api-key
AZURE_OPENAI_API_KEY_SECONDARY=your-secondary-api-key
