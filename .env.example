# ==============================================================
# AI Assistant Market — Environment Variables
# ==============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.
# ==============================================================

# Auth secret for JWT token signing (change in production!)
AUTH_SECRET=your-secret-key-here

# Base URL for the application
NEXTAUTH_URL=http://localhost:3001

# --------------------------------------------------------------
# LLM Provider Configuration
# --------------------------------------------------------------
# Options: "groq" (recommended, free tier), "azure-openai", or "mock" (demo mode)
LLM_PROVIDER=groq

# Groq Configuration (recommended — free, fast inference)
# Sign up at https://console.groq.com for a free API key
LLM_API_KEY=your-groq-api-key
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Azure OpenAI Configuration (alternative, requires Azure subscription)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY_PRIMARY=your-primary-api-key
